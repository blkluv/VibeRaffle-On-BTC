{
    "targets": {
        "release": {
            "outFile": "build/VibeRaffle.wasm",
            "textFile": "build/VibeRaffle.wat",
            "sourceMap": false,
            "optimizeLevel": 3,
            "shrinkLevel": 1,
            "converge": false,
            "noAssert": false
        },
        "debug": {
            "outFile": "build/VibeRaffle.debug.wasm",
            "textFile": "build/VibeRaffle.debug.wat",
            "sourceMap": true,
            "debug": true
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "enable": ["sign-extension", "mutable-globals", "nontrapping-f2i", "bulk-memory", "simd", "reference-types", "multi-value"],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 16,
        "converge": true,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "noAssert": false,
        "exportStart": "start"
    }
}
